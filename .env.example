# Copy to .env for local use, or set these in your host's dashboard.
# Do NOT commit a real .env (it's gitignored).

# Connect to real Common Crawl (false) vs offline mock data (true)
DEMO_MODE=false

# Where job data is stored. On a host, point this at a persistent disk.
# Locally you can leave it unset (defaults to the app folder).
# DATA_DIR=/var/data

# Access control — set ONE of these so the app isn't open to the world.
#   Shared password (any username works):
APP_PASSWORD=change-me-to-a-long-random-password
#   OR specific logins (comma-separated user:password pairs):
# AUTH_USERS=alice:pw-alice,bob:pw-bob

# Port is usually injected by the host; locally defaults to 3000.
# PORT=3000
